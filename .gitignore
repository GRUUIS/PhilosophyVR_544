# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

# ------------------------------
# Unreal Editor cache / registry
# ------------------------------
**/AssetRegistryCache/
**/CachedAssetRegistry*.bin
**/Cooked/
**/StagedBuilds/

# ------------------------------
# Unreal autosaves / backups
# ------------------------------
**/Autosaves/
**/Backup/
**/*_Auto*.uasset
**/*_Auto*.umap

# ------------------------------
# Logs, crash reports, temp
# ------------------------------
*.log
*.tmp
*.temp
*.bak
*.old
*.dmp
*.pdb
*.sym
CrashReportClient/

# ------------------------------
# IDE / editor settings
# ------------------------------
.idea/
.vscode/
*.code-workspace

# ------------------------------
# OS junk
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini


# ---- Unreal project is in subfolder: PhilosopherVR_544/ ----
PhilosopherVR_544/.vs/
PhilosopherVR_544/Binaries/
PhilosopherVR_544/DerivedDataCache/
PhilosopherVR_544/Intermediate/
PhilosopherVR_544/Saved/
PhilosopherVR_544/Build/

# Also ignore generated stuff under Plugins inside that project
PhilosopherVR_544/Plugins/**/Binaries/
PhilosopherVR_544/Plugins/**/Intermediate/

# Registry / autosaves / backups
PhilosopherVR_544/**/AssetRegistryCache/
PhilosopherVR_544/**/CachedAssetRegistry*.bin
PhilosopherVR_544/**/Autosaves/
PhilosopherVR_544/**/Backup/
PhilosopherVR_544/**/*_Auto*.uasset
PhilosopherVR_544/**/*_Auto*.umap

# Art Assets
PhilosopherVR_544/Content/Anemoia/
PhilosopherVR_544/Content/Classic_Office/
PhilosopherVR_544/Content/VictorianLivingRoom/
PhilosopherVR_544/Content/Suburbs/